IDD_ABOUTBOX DIALOGEX 0, 0, 323, 313
STYLE DS_ABSALIGN | DS_SETFONT | DS_CENTER | WS_CAPTION
CAPTION "소프트웨어 정보"
FONT 9, "굴림", 0, 0, 0x0
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,7,15,20,20
    LTEXT           "CMI Version 1.0",IDC_STATIC_ABOUTBOXDLG_1,32,16,186,8,SS_NOPREFIX
    LTEXT           "Copyright (C) 2017 Synapse Imaging co.,Ltd",IDC_STATIC_ABOUTBOXDLG_2,32,31,186,8
    LTEXT           "프로그램 생성 시간:",IDC_STATIC_ABOUTBOXDLG_3,32,47,196,8,SS_NOPREFIX
    DEFPUSHBUTTON   "확인",IDOK,242,17,64,31,WS_GROUP
    LTEXT           "소프트웨어 변경 내역",IDC_STATIC_ABOUTBOXDLG_4,127,70,75,8
    EDITTEXT        IDC_EDIT_RELEASE,7,89,309,217,ES_MULTILINE | ES_AUTOVSCROLL | ES_AUTOHSCROLL | ES_READONLY | WS_VSCROLL | WS_HSCROLL
END

IDD_uScan_FORM DIALOGEX 0, 0, 1093, 572
STYLE DS_SETFONT | WS_CHILD | WS_BORDER
FONT 9, "Arial", 400, 0, 0x0
BEGIN
